# Скопируйте этот файл в .env в КОРНЕ проекта (рядом с package.json):
#   PowerShell: .\scripts\setup-env.ps1
#
# Gmail: включите двухэтапную аутентификацию, затем пароль приложения:
# https://myaccount.google.com/apppasswords
# В SMTP_PASS — только пароль приложения (16 символов), НЕ обычный пароль от почты.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=zerno.coffee.by@gmail.com
SMTP_PASS=

MAIL_FROM="Zerno Coffee" <zerno.coffee.by@gmail.com>
